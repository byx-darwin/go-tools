{
  "permissions": {
    "allow": [
      "Bash(go build *)",
      "Bash(go vet *)",
      "Bash(go test *)",
      "Bash(go mod *)",
      "Bash(go work *)",
      "Bash(go get *)",
      "Bash(go list *)",
      "Bash(go doc *)",
      "Bash(go run *)",
      "Bash(go version *)",
      "Bash(go clean *)",
      "Bash(go fmt *)",
      "Bash(gofmt *)",
      "Bash(git *)",
      "Bash(python3 *)",
      "Bash(pre-commit *)",
      "Bash(mkdir *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(sed *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(echo *)",
      "Bash(chmod *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "tokenless hook rewrite --target claude --project go-tools --user-name baoyx"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(?!Bash$).*",
        "hooks": [
          {
            "type": "command",
            "command": "tokenless hook compress --semantic --target claude --project go-tools --user-name baoyx"
          }
        ]
      }
    ]
  },
  "env": {
    "RTK_SKIP_HOOK_CHECK": "1"
  }
}